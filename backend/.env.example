# Groq LLM API key
GROQ_API_KEY=your_groq_api_key_here

# Pinecone vector database API key
PINECONE_API_KEY=your_pinecone_api_key_here

# Pinecone index name
PINECONE_INDEX=your_pinecone_index_name_here
PINECONE_INDEX_NAME=ai-agent-platform

# Pinecone dimension
PINECONE_DIMENSION=384

# Embedding model to use
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# MCP Server — Model Context Protocol
#
# The MCP server runs as a separate process alongside FastAPI and exposes
# agent tools over JSON-RPC.  The agent SDK connects to it on startup,
# discovers available tools, and calls them on behalf of the LLM.
#
# MCP_SERVER_HOST — hostname/IP where the MCP server listens.
#                   Use "localhost" for local dev; override in production
#                   (e.g. the container/service name in Docker Compose).
# MCP_SERVER_PORT — port for the MCP server.  Must differ from FastAPI (8000)
#                   so each service can be scaled and secured independently.
# MCP_SERVER_NAME — human-readable label returned in server-info responses;
#                   lets agents verify they've connected to the right service.
# ---------------------------------------------------------------------------
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001
MCP_SERVER_NAME=ai-agent-platform-mcp
